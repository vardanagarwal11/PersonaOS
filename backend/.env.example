# --- Server ---
PORT=4000

# --- Stellar / Soroban (testnet defaults) ---
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed EmpAttestor contract id (from `stellar contract deploy`)
EMP_CONTRACT_ID=

# Issuer account SECRET (S...). This account signs attestations and must be the
# same address passed to the contract's init(). Fund it on testnet via friendbot.
EMP_ISSUER_SECRET=

# --- Vault encryption (§6) ---
# 32+ char random secret. Wraps per-user AES-256-GCM data keys. Keep it safe:
# rotating it makes existing encrypted vaults unreadable.
EMP_VAULT_MASTER_KEY=

# --- AI engine (Gemini) ---
# Get a free key at https://aistudio.google.com/apikey
# If GEMINI_API_KEY is empty, the server falls back to mock profiles so the
# crypto + chain flow still works end to end.
GEMINI_API_KEY=
# Override if your free tier exposes different model ids:
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Demo test accounts (optional convenience, not used in the Freighter flow) ---
DEMO_SUBJECT_PUB=
DEMO_SUBJECT_SECRET=
